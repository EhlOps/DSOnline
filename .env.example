# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real passwords.
# Tip: run `python3 setup.py configure` to generate this file interactively.

# Number of players (1–8)
NUM_PLAYERS=2

# VNC password for Player 1's browser session
PLAYER1_VNC_PASSWORD=change_me_player1

# VNC password for Player 2's browser session (only needed when NUM_PLAYERS=2)
PLAYER2_VNC_PASSWORD=change_me_player2

# Desktop resolution streamed to each player (WxH)
# Options: 1280x720 (recommended), 1920x1080, 1024x768, 800x600
VNC_GEOMETRY=1280x720

# Domain name or IP used by setup.py to generate the nginx config
DOMAIN=localhost
